<Window x:Class="lab34.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="3D Model Viewer" 
        Height="900" Width="1440" 
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="Black">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2C2C2C" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnOpenFile" 
                        Click="BtnOpenFile_Click" 
                        Width="120" Height="35" 
                        Margin="5" 
                        Background="#FF9800" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Open File" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- Добавьте эти кнопки в StackPanel в верхней части Grid -->
                <Button Content="Load Diffuse" Click="BtnLoadDiffuse_Click" Width="100" Margin="5" Background="#4CAF50" Foreground="White"/>
                <Button Content="Load Normal" Click="BtnLoadNormal_Click" Width="100" Margin="5" Background="#2196F3" Foreground="White"/>
                <Button Content="Load Specular" Click="BtnLoadSpecular_Click" Width="100" Margin="5" Background="#9C27B0" Foreground="White"/>
                <Button x:Name="btnResetCamera" 
                        Click="BtnResetCamera_Click" 
                        Width="120" Height="35" 
                        Margin="5" 
                        Background="#FF9800" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Reset Camera" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="btnWireframe" 
                        Click="BtnWireframe_Click" 
                        Width="120" Height="35" 
                        Margin="5" 
                        Background="#FF9800" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Wireframe" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Border Width="1" Background="#555" Margin="10,5"/>
            </StackPanel>
        </Border>
        
        <Grid x:Name="gridDisplay" Grid.Row="1" Background="Black">
            <Image x:Name="imageContainer" 
                   Stretch="Uniform" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
        </Grid>
        
        <Border Grid.Row="1" 
                Background="#80000000" 
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Left" 
                Margin="10" 
                Padding="10,5" 
                CornerRadius="5">
        </Border>
    </Grid>
</Window>